# ====================================
# Environment Variables - Copy this to .env and fill in your values
# ====================================
# cp .env.example .env
# ====================================

# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_password_here
POSTGRES_DB=user_post_api
POSTGRES_PORT=5432

# Redis
REDIS_PORT=6379

# API
API_PORT=8080

# JWT Secret (ganti dengan secret key yang kuat!)
JWT_SECRET=your-secret-key-change-in-production

# Connection URLs
# For local development (host = localhost)
DATABASE_URL=postgres://postgres:your_password_here@localhost:5432/user_post_api?sslmode=disable

# For Docker (host = service name)
DATABASE_URL_DOCKER=postgres://postgres:your_password_here@postgres:5432/user_post_api?sslmode=disable
REDIS_URL=redis://redis:6379
